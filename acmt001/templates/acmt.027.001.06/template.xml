<?xml version="1.0" encoding="UTF-8"?>
<Document xmlns="urn:iso:std:iso:20022:tech:xsd:acmt.027.001.06"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
	<AcctSwtchInfReq>
		<MsgId>
			<Id>{{msg_id}}</Id>
			<CreDtTm>{{creation_date_time}}</CreDtTm>
		</MsgId>
		<AcctSwtchDtls>
			<UnqRefNb>{{switch_reference}}</UnqRefNb>
			<RtgUnqRefNb>{{routing_id}}</RtgUnqRefNb>
			<SwtchRcvdDtTm>{{creation_date_time}}</SwtchRcvdDtTm>
			<SwtchTp>FULL</SwtchTp>
			<SwtchSts>{{switch_status_cd}}</SwtchSts>
			<BalTrfWndw>{{balance_transfer_window_cd}}</BalTrfWndw>
		</AcctSwtchDtls>
		<NewAcct>
			<Acct>
				<Id>
					<IBAN>{{new_account_id}}</IBAN>
				</Id>
				<Svcr>
					<FinInstnId>
						<BICFI>{{new_account_servicer_bic}}</BICFI>
					</FinInstnId>
				</Svcr>
			</Acct>
			<AcctPty>
				<CurNm>
					<Srnm>{{account_owner_surname}}</Srnm>
					<GvnNm>{{account_owner_given_name}}</GvnNm>
				</CurNm>
			</AcctPty>
		</NewAcct>
		<OdAcct>
			<Id>
				<IBAN>{{old_account_id}}</IBAN>
			</Id>
			<Svcr>
				<FinInstnId>
					<BICFI>{{old_account_servicer_bic}}</BICFI>
				</FinInstnId>
			</Svcr>
		</OdAcct>
	</AcctSwtchInfReq>
</Document>
